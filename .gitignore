data/
cat > .gitignore << 'EOF'
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Data folder
data/

# Environments
.env
.env.local
.env.*.local
.venv/
venv/
env/
ENV/

# OS generated
.DS_Store
.DS_Store?

# Logs/PIDs
*.log
*.pid

# Distribution / packaging
.Python
build/
dist/
eggs/
*.egg-info/
.installed.cfg
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints
*.ipynb_checkpoints

# OS
Thumbs.db
.DS_Store
EOF
data/
benchmarks/
rust/url_dedup/target/
